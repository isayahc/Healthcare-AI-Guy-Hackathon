# Server
PORT=8787
# Optional: override the SQLite artifact database location.
SQLITE_DB_PATH=./data/clinical-app-studio.sqlite

# Auth
# Clerk publishable key for the Vite frontend.
# If omitted, the UI offers demo practitioner sign-in after terms acceptance.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
# Optional, reserved for future server-side Clerk token checks.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# OpenAI artifact generation
OPENAI_API_KEY=sk_your_openai_api_key_here
OPENAI_MODEL=gpt-4.1
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# Baseten patient-app runtime LLMs
BASETEN_API_KEY=your_baseten_api_key_here
BASETEN_CHAT_URL=https://inference.baseten.co/v1/chat/completions
# Must point at a multimodal Baseten-served model for runtime patient-app LLM calls.
BASETEN_MULTIMODAL_MODEL=moonshotai/Kimi-K2.6

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Firecrawl artifact research/source extraction
FIRECRAWL_API_KEY=fc_your_firecrawl_api_key_here
# FIRECRAWL_API is also accepted as a local alias.
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
